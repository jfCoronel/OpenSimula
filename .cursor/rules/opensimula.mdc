 "supply_fan": "supply_fan", "air_flow": 1.0, "outdoor_air_fraction": 0.15,
 "supply_heating_setpoint": "12", "supply_cooling_setpoint": "14",
 "spaces_setpoint": ["20", "22"], "system_on_off": "1",
